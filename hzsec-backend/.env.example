# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
WEB_ORIGIN=http://localhost:3000

# ─── Database (Railway Postgres) ─────────────────────────────────────────────
# Railway injects this automatically when you attach the Postgres plugin.
# Locally: docker run -d --name hzsec-pg -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16
DATABASE_URL=postgresql://postgres:dev@localhost:5432/hzsec_dev

# ─── Clerk (auth) ────────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com/ → API Keys → Secret keys
# Use the "test" instance keys until you're ready for production.
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# ─── Stripe (TEST MODE ONLY until LLC is incorporated) ───────────────────────
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Get from: https://dashboard.stripe.com/test/webhooks → your endpoint → "Signing secret"
# Locally use the Stripe CLI: `stripe listen --forward-to localhost:8080/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Price IDs — create three Products + Prices in Stripe dashboard.
# See README → "Stripe setup" for the exact click-path.
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_PRO_ANNUAL=price_REPLACE_ME
STRIPE_PRICE_TEAM_MONTHLY=price_REPLACE_ME

# ─── Anthropic (server-side proxy key) ───────────────────────────────────────
# Single key shared by all paying users. Users never see it.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_API_VERSION=2023-06-01
