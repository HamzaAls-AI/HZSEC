# Where the backend is reachable. In dev: localhost. In prod: api.hzsec.io.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Clerk — get from https://dashboard.clerk.com/ → API keys
# Publishable key is safe to ship in browser bundles. Secret key stays here.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Where Clerk should send users after sign-in / sign-up. Keep these stable —
# they're also referenced by Clerk's dashboard "Paths" config.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
